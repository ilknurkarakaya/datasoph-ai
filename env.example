# DataSoph AI - Environment Variables
# Copy this file to .env if you need custom settings

# Application Settings
DEBUG=True
MAX_FILE_SIZE_MB=50
UPLOAD_DIRECTORY=./uploads

# API Keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Real Intelligence - OpenAI Configuration (REQUIRED for intelligent AI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Hyper Intelligence - Anthropic Claude Configuration (OPTIONAL for dual-AI)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# CORS Settings (add your frontend URLs)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"] 