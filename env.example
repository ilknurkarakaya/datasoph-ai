# DataSoph AI - Environment Variables Configuration
# Copy this file to .env and fill in your actual API keys

# ==============================================
# OpenRouter API Configuration (Primary LLM)
# ==============================================
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# ==============================================
# OpenAI API Configuration (Optional Fallback)
# ==============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ==============================================
# Server Configuration
# ==============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=True

FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# ==============================================
# File Upload Settings
# ==============================================
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=csv,xlsx,xls,json,txt,pdf
UPLOAD_DIRECTORY=uploads
FIGURES_DIRECTORY=figures
REPORTS_DIRECTORY=reports

# ==============================================
# AI Model Settings
# ==============================================
DEFAULT_MODEL=anthropic/claude-3.5-sonnet
MAX_RESPONSE_LENGTH=4000
CONVERSATION_MEMORY_LIMIT=20

# ==============================================
# Security Settings
# ==============================================
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==============================================
# Logging Configuration
# ==============================================
LOG_LEVEL=INFO

# ==============================================
# Performance Settings
# ==============================================
ENABLE_CACHE=True
CACHE_TTL_SECONDS=3600
MAX_WORKERS=4
REQUEST_TIMEOUT_SECONDS=30
